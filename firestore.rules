rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ────────────────────────────────────────────────────────────────
    // Any logged-in user can read a worker's profile (needed for search page).
    // Users can only write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── jobs ─────────────────────────────────────────────────────────────────
    // Client creates a job. Both the client and the assigned worker can read it.
    // Only the client or worker involved can update it.
    match /jobs/{jobId} {
      allow read: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.workerId == request.auth.uid);

      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;

      allow update: if request.auth != null &&
        (resource.data.clientId == request.auth.uid ||
         resource.data.workerId == request.auth.uid);
    }

    // ── reviews ──────────────────────────────────────────────────────────────
    // Anyone logged in can read reviews (shown on worker profile).
    // Only a client can create a review, and only for themselves.
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.clientId == request.auth.uid;
    }

    // ── payments ─────────────────────────────────────────────────────────────
    // Written by the server (Firebase Admin SDK) — clients can only read their own.
    match /payments/{txRef} {
      allow read: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow write: if false; // server-only via Admin SDK
    }
  }
}
